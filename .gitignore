# Python
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Env / secrets
.env
.env.*
!.env.example

# Data (large / regenerable — see data/README.md for how to fetch it).
# Raw datasets live outside the repo at ~/.interpose/data/, never here — this only
# guards against someone accidentally dropping a raw file into ./data/ locally.
data/*.csv
data/*.parquet
data/*.txt

# Terraform
terraform/**/.terraform/
terraform/**/*.tfstate
terraform/**/*.tfstate.*
terraform/**/.terraform.lock.hcl

# Helm
charts/**/charts/
charts/**/*.tgz

# IDE / OS
.DS_Store
.vscode/
.idea/

# Logs
*.log

# Local dev cluster (scripts/dev-up.sh / dev-down.sh)
.dev-up.pids
