# Copy to .env for local dev. Matches docker-compose.yaml's postgres/redis services.
DATABASE_URL=postgresql+psycopg://interpose:interpose_dev@localhost:5433/interpose
REDIS_URL=redis://localhost:6379/0

# Free tier at https://console.groq.com -- only needed for Agents A2 (optional
# narrative)/A3/A4's real LLM calls. Automated tests mock the LLM call and never need
# this set; it's only used for the one-off manual smoke test (see concept 24).
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b
