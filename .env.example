# Copy to .env for local dev. Matches docker-compose.yaml's postgres/redis services.
# More settings (LLM provider/API key, ...) get added here as the project actually
# needs them -- see docs/ROADMAP.md for what's next.
DATABASE_URL=postgresql+psycopg://interpose:interpose_dev@localhost:5433/interpose
REDIS_URL=redis://localhost:6379/0
